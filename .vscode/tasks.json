{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-backend",
      "type": "shell",
      "command": "dotnet build",
      "options": { "cwd": "${workspaceFolder}/backend/CmsApi" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch-backend",
      "type": "shell",
      "command": "dotnet watch --no-hot-reload",
      "options": { "cwd": "${workspaceFolder}/backend/CmsApi" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" },
      "problemMatcher": {
        "base": "$msCompile",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building\\.\\.\\.",
          "endsPattern": "Application started\\."
        }
      }
    },
    {
      "label": "start-frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" },
      "problemMatcher": {
        "pattern": { "regexp": "^$", "file": 1, "location": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:.*localhost:5173"
        }
      }
    },
    {
      "label": "install-frontend",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "start-full-stack",
      "dependsOn": ["watch-backend", "start-frontend"],
      "dependsOrder": "parallel",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    }
  ]
}
